// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts    Account[]
  sessions    Session[]
  linkedInData LinkedInData?
  gitHubData   GitHubData?
  resumes      Resume[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model LinkedInData {
  id             String   @id @default(cuid())
  userId         String   @unique
  headline       String?
  summary        String?  @db.Text
  location       String?
  profileUrl     String?
  avatarUrl      String?
  experience     Json     @default("[]")
  education      Json     @default("[]")
  skills         Json     @default("[]")
  certifications Json     @default("[]")
  languages      Json     @default("[]")
  volunteer      Json     @default("[]")
  achievements   Json     @default("[]")
  raw            Json?
  fetchedAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("linkedin_data")
}

model GitHubData {
  id            String   @id @default(cuid())
  userId        String   @unique
  username      String
  bio           String?  @db.Text
  avatarUrl     String?
  profileUrl    String?
  publicRepos   Int      @default(0)
  followers     Int      @default(0)
  repositories  Json     @default("[]")
  pinnedRepos   Json     @default("[]")
  topLanguages  Json     @default("{}")
  topFrameworks Json     @default("[]")
  totalStars    Int      @default(0)
  totalForks    Int      @default(0)
  raw           Json?
  fetchedAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("github_data")
}

model Resume {
  id          String   @id @default(cuid())
  userId      String
  title       String
  targetRole  String?
  template    String   @default("classic-ats")
  blocks      Json     @default("[]")
  atsScore    Int?
  atsDetails  Json?
  shareToken  String?  @unique @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  editHistory EditHistory[]
  exports     ExportedFile[]

  @@index([userId])
  @@map("resumes")
}

model EditHistory {
  id        String   @id @default(cuid())
  resumeId  String
  snapshot  Json
  label     String?
  createdAt DateTime @default(now())

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId])
  @@map("edit_history")
}

model ExportedFile {
  id        String   @id @default(cuid())
  resumeId  String
  format    String   // pdf | docx | link
  url       String?
  size      Int?
  createdAt DateTime @default(now())

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@map("exported_files")
}
